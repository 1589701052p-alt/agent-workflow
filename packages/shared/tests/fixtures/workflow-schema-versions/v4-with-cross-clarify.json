{
  "$schema_version": 4,
  "inputs": [{ "kind": "text", "key": "topic", "label": "Topic", "required": true }],
  "nodes": [
    { "id": "in_1", "kind": "input", "inputKey": "topic" },
    {
      "id": "designer_1",
      "kind": "agent-single",
      "agentName": "v4-designer",
      "promptTemplate": "Design for {{topic}}."
    },
    {
      "id": "questioner_1",
      "kind": "agent-single",
      "agentName": "v4-questioner",
      "promptTemplate": "Audit the design.\n{{design}}"
    },
    {
      "id": "cross_1",
      "kind": "clarify-cross-agent",
      "title": "Cross-agent clarify on v4 fixture",
      "sessionModeForDesigner": "isolated",
      "sessionModeForQuestioner": "isolated"
    },
    {
      "id": "out_1",
      "kind": "output",
      "ports": [{ "name": "design", "bind": { "nodeId": "designer_1", "portName": "design" } }]
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source": { "nodeId": "in_1", "portName": "topic" },
      "target": { "nodeId": "designer_1", "portName": "topic" }
    },
    {
      "id": "e2",
      "source": { "nodeId": "designer_1", "portName": "design" },
      "target": { "nodeId": "questioner_1", "portName": "design" }
    },
    {
      "id": "e3_auto_clarify",
      "source": { "nodeId": "questioner_1", "portName": "__clarify__" },
      "target": { "nodeId": "cross_1", "portName": "questions" }
    },
    {
      "id": "e4_auto_to_questioner",
      "source": { "nodeId": "cross_1", "portName": "to_questioner" },
      "target": { "nodeId": "questioner_1", "portName": "__clarify_response__" }
    },
    {
      "id": "e5_manual_to_designer",
      "source": { "nodeId": "cross_1", "portName": "to_designer" },
      "target": { "nodeId": "designer_1", "portName": "__external_feedback__" }
    },
    {
      "id": "e6",
      "source": { "nodeId": "designer_1", "portName": "design" },
      "target": { "nodeId": "out_1", "portName": "design" }
    }
  ],
  "outputs": []
}
